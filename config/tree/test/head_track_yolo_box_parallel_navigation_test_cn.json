{
  "tree": {
    "name": "Sequence",
    "label": "头部盯YOLO箱体并行双点导航测试",
    "params": {
      "memory": {
        "value": "True",
        "source": "CUSTOM"
      }
    },
    "childs": [
      {
        "name": "EnsureMoveBoxServices",
        "label": "初始化 move_box 控制实例",
        "params": {
          "services_key": {
            "value": "move_box_services",
            "source": "CUSTOM"
          },
          "skip_arm_motion": {
            "value": "True",
            "source": "CUSTOM"
          },
          "skip_torso_motion": {
            "value": "True",
            "source": "CUSTOM"
          },
          "skip_claw_motion": {
            "value": "True",
            "source": "CUSTOM"
          }
        }
      },
      {
        "name": "WaitForEnter",
        "label": "共享实例创建后暂停（按 Enter）",
        "params": {
          "message": {
            "value": "共享实例已创建，按 Enter 开始并行测试：头部持续盯箱 + 手动双点导航...",
            "source": "CUSTOM"
          }
        }
      },
      {
        "name": "Parallel",
        "label": "并行运行头部盯箱与双点导航",
        "params": {
          "policy": {
            "value": "SuccessOnAll",
            "source": "CUSTOM"
          },
          "synchronise": {
            "value": "False",
            "source": "CUSTOM"
          }
        },
        "childs": [
          {
            "name": "MoveBoxTrackHeadToYoloBox",
            "label": "头部持续盯住YOLO最近箱体",
            "params": {
              "services_key": {
                "value": "move_box_services",
                "source": "CUSTOM"
              },
              "yolo_topic": {
                "value": "/yolo/target_poses",
                "source": "CUSTOM"
              },
              "target_select_frame": {
                "value": "base_link",
                "source": "CUSTOM"
              },
              "control_mode": {
                "value": "latched_map_target",
                "source": "CUSTOM"
              },
              "control_frame": {
                "value": "map",
                "source": "CUSTOM"
              },
              "track_interval_sec": {
                "value": "0.1",
                "source": "CUSTOM"
              },
              "max_delta_yaw_deg": {
                "value": "3.0",
                "source": "CUSTOM"
              },
              "max_delta_pitch_deg": {
                "value": "2.0",
                "source": "CUSTOM"
              },
              "lock_residual_fast_m": {
                "value": "0.12",
                "source": "CUSTOM"
              },
              "lock_residual_slow_m": {
                "value": "0.35",
                "source": "CUSTOM"
              },
              "lock_fast_alpha": {
                "value": "0.5",
                "source": "CUSTOM"
              },
              "lock_slow_alpha": {
                "value": "0.2",
                "source": "CUSTOM"
              },
              "lock_pending_confirm_count": {
                "value": "2",
                "source": "CUSTOM"
              },
              "lock_pending_match_m": {
                "value": "0.2",
                "source": "CUSTOM"
              },
              "chassis_yaw_rate_slow_update_deg_s": {
                "value": "12.0",
                "source": "CUSTOM"
              },
              "no_target_log_interval_sec": {
                "value": "1.0",
                "source": "CUSTOM"
              },
              "failure_log_interval_sec": {
                "value": "1.0",
                "source": "CUSTOM"
              },
              "axis_length_m": {
                "value": "1.0",
                "source": "CUSTOM"
              },
              "debug_enabled": {
                "value": "True",
                "source": "CUSTOM"
              },
              "debug_point_topic": {
                "value": "/head_track_yolo_target_point",
                "source": "CUSTOM"
              },
              "debug_marker_topic": {
                "value": "/head_track_yolo_marker",
                "source": "CUSTOM"
              },
              "debug_frame": {
                "value": "map",
                "source": "CUSTOM"
              },
              "chassis_frame": {
                "value": "melon_odom",
                "source": "CUSTOM"
              }
            }
          },
          {
            "name": "Repeat",
            "label": "循环按Enter触发双点导航",
            "params": {
              "num_success": {
                "value": "-1",
                "source": "CUSTOM"
              }
            },
            "childs": [
              {
                "name": "Sequence",
                "label": "单轮双点导航",
                "params": {
                  "memory": {
                    "value": "True",
                    "source": "CUSTOM"
                  }
                },
                "childs": [
                  {
                    "name": "WaitForEnter",
                    "label": "按Enter导航到测试点1",
                    "params": {
                      "message": {
                        "value": "头部盯箱运行中，按 Enter 导航到测试点1...",
                        "source": "CUSTOM"
                      }
                    }
                  },
                  {
                    "name": "HttpNavigateToPose",
                    "label": "导航到测试点1",
                    "params": {
                      "x": {
                        "value": "0.9",
                        "source": "CUSTOM"
                      },
                      "y": {
                        "value": "1.2",
                        "source": "CUSTOM"
                      },
                      "yaw": {
                        "value": "-136.0",
                        "source": "CUSTOM"
                      },
                      "chassis_url": {
                        "value": "http://localhost:8081",
                        "source": "CUSTOM"
                      },
                      "navigation_timeout_sec": {
                        "value": "600",
                        "source": "CUSTOM"
                      },
                      "poll_interval_sec": {
                        "value": "0.2",
                        "source": "CUSTOM"
                      }
                    }
                  },
                  {
                    "name": "WaitForEnter",
                    "label": "按Enter导航到测试点2",
                    "params": {
                      "message": {
                        "value": "测试点1导航完成，按 Enter 导航到测试点2...",
                        "source": "CUSTOM"
                      }
                    }
                  },
                  {
                    "name": "HttpNavigateToPose",
                    "label": "导航到测试点2",
                    "params": {
                      "x": {
                        "value": "0.9",
                        "source": "CUSTOM"
                      },
                      "y": {
                        "value": "0.0",
                        "source": "CUSTOM"
                      },
                      "yaw": {
                        "value": "153.0",
                        "source": "CUSTOM"
                      },
                      "chassis_url": {
                        "value": "http://localhost:8081",
                        "source": "CUSTOM"
                      },
                      "navigation_timeout_sec": {
                        "value": "600",
                        "source": "CUSTOM"
                      },
                      "poll_interval_sec": {
                        "value": "0.2",
                        "source": "CUSTOM"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
